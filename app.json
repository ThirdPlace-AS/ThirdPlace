{
  "expo": {
    "name": "ThirdPlace",
    "slug": "ThirdPlace",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "thirdplace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thirdplaceofficial.ThirdPlace",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ThirdPlace uses your location to show nearby experiences.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ThirdPlace uses your location to show nearby experiences."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172b"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.thirdplaceofficial.ThirdPlace"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      ["@rnmapbox/maps"],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ThirdPlace to use your location."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43fc8f3a-e6ed-4dee-a6df-4bc14ca80243"
      }
    },
    "owner": "thirdplaceofficial"
  }
}
